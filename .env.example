# ══════════════════════════════════════════════
#  对话模型（兼容 OpenAI API 格式）
# ══════════════════════════════════════════════
CHAT_MODEL=Qwen/Qwen3-VL-4B-AWQ
LLM_API_KEY=abc123
LLM_BASE_URL=http://localhost:7890/v1
LLM_TEMPERATURE=0.0

# ══════════════════════════════════════════════
#  Embedding 模型
# ══════════════════════════════════════════════
EMBED_MODEL=text-embedding-v4
EMBED_API_KEY=your-embed-api-key-here
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ══════════════════════════════════════════════
#  RAG 检索参数
# ══════════════════════════════════════════════
RETRIEVAL_TOP_K=3
RETRIEVAL_SCORE_THRESHOLD=0.5

# ══════════════════════════════════════════════
#  向量库持久化
# ══════════════════════════════════════════════
VECTOR_STORE_PATH=./vector_store
# 设为 true 则每次启动都重建索引（数据变更时使用）
VECTOR_STORE_AUTO_REBUILD=false

# ══════════════════════════════════════════════
#  其他
# ══════════════════════════════════════════════
# 自定义数据库路径（JSON 格式：{"弦号": "描述"}）
# SHIP_DB_PATH=./data/ships.json
LOG_LEVEL=INFO
